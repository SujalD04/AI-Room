generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── User and Auth ───

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  email        String   @unique
  passwordHash String
  nickname     String?
  bio          String?
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  hostedRooms    Room[]               @relation("RoomHost")
  memberships    RoomMember[]
  apiKeys        ApiKey[]
  messages       MessageNode[]
  notes          Note[]
  threads        ConversationThread[] @relation("ThreadCreator")
  todoAssignees  TodoItem[]           @relation("TodoAssignee")

  @@index([email])
  @@index([username])
}

// ─── Rooms ───

model Room {
  id         String   @id @default(uuid())
  name       String
  slug       String   @unique
  hostId     String
  isPrivate  Boolean  @default(false)
  password   String?

  maxMembers Int?      // NEW
  isActive   Boolean   @default(true) // NEW
  settings   Json?     // NEW

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  host    User         @relation("RoomHost", fields: [hostId], references: [id])
  members RoomMember[]
  threads ConversationThread[]
  notes   Note[]
  todos   TodoItem[]

  @@index([slug])
  @@index([hostId])
}

model RoomMember {
  id        String   @id @default(uuid())
  roomId    String
  userId    String
  role      String   @default("MEMBER") // HOST, ADMIN, MEMBER
  joinedAt  DateTime @default(now())

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
}

// ─── API Keys ───

model ApiKey {
  id           String   @id @default(uuid())
  userId       String
  provider     Provider
  keyName      String
  keyHash      String

  label        String?  // NEW
  encryptedKey String?  // NEW
  iv           String?  // NEW
  authTag      String?  // NEW

  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum Provider {
  openai
  anthropic
  google
  openrouter
  mistral
  deepseek
  together
}

// ─── DAG Conversation Tree ───

model ConversationThread {
  id          String   @id @default(uuid())
  roomId      String
  creatorId   String?  // The user who created this thread (owner of the BYOK key)
  title       String
  modelConfig Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  room     Room          @relation(fields: [roomId], references: [id], onDelete: Cascade)
  creator  User?         @relation("ThreadCreator", fields: [creatorId], references: [id], onDelete: SetNull)
  messages MessageNode[]

  @@index([roomId])
  @@index([creatorId])
}

model MessageNode {
  id         String     @id @default(uuid())
  threadId   String
  parentId   String?    // null for root messages
  authorType AuthorType
  authorId   String?    // null for AI/SYSTEM
  modelId    String?    // which LLM model produced this
  content    String     @db.Text
  metadata   Json       @default("{}")
  createdAt  DateTime   @default(now())

  thread   ConversationThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author   User?              @relation(fields: [authorId], references: [id], onDelete: SetNull)

  // DAG edges
  parentEdges  MessageEdge[] @relation("EdgeChild")
  childEdges   MessageEdge[] @relation("EdgeParent")

  @@index([threadId])
  @@index([parentId])
  @@index([authorId])
}

model MessageEdge {
  id       String @id @default(uuid())
  parentId String
  childId  String

  edgeType String @default("REPLY") // NEW

  parent MessageNode @relation("EdgeParent", fields: [parentId], references: [id], onDelete: Cascade)
  child  MessageNode @relation("EdgeChild", fields: [childId], references: [id], onDelete: Cascade)

  @@unique([parentId, childId])
}

enum AuthorType {
  USER
  AI
  SYSTEM
}

// ─── Features ───

model Note {
  id        String   @id @default(uuid())
  roomId    String
  authorId  String
  title     String
  content   Json     @default("{}")

  type      String   @default("NOTE") // NEW
  isPinned  Boolean  @default(false)  // NEW

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  room   Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: SetNull)

  todos  TodoItem[] // NEW relation

  @@index([roomId])
}

model TodoItem {
  id          String    @id @default(uuid())

  roomId      String
  noteId      String?   // NEW

  title       String
  description String?
  isCompleted Boolean   @default(false)

  order       Int       @default(0) // NEW

  dueDate     DateTime?
  assigneeId  String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  room     Room  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  note     Note? @relation(fields: [noteId], references: [id], onDelete: Cascade) // NEW

  assignee User? @relation("TodoAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([roomId])
  @@index([noteId])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  email     String
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}
