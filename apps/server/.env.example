# ──────────────────────────────────────────
# AIRoom Server — Environment Example
# Copy to .env and fill in production values
# ──────────────────────────────────────────

# ── Server ──
# Change to 'production' on the VM
NODE_ENV=development
PORT=3001
# Comma-separated list of allowed origins (e.g. your Vercel domain and preview wildcards)
CLIENT_URL=http://localhost:3000,https://airoom.vercel.app,https://airoom-*-yourusername.vercel.app

# ── Database ──
# Use 'postgres' as host when running via docker-compose
DATABASE_URL=postgresql://postgres:changeme@localhost:5432/airoom?schema=public

# ── Redis ──
# Use 'redis' as host when running via docker-compose
REDIS_URL=redis://localhost:6379

# ── Auth ──
# Run `openssl rand -base64 48` to generate a secure secret
JWT_SECRET=dev-secret-change-me
JWT_EXPIRES_IN=7d

# ── Encryption (BYOK) ──
# 32-character hex string. Run `openssl rand -hex 16`
ENCRYPTION_KEY=29D93DD1E39DBAFFB6210D6BC004C0A2

# ── mediasoup ──
# Set to the public IP of your VM in production
MEDIASOUP_LISTEN_IP=0.0.0.0
MEDIASOUP_ANNOUNCED_IP=127.0.0.1
MEDIASOUP_MIN_PORT=40000
MEDIASOUP_MAX_PORT=49999

# ── Email (SMTP) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="AIRoom <noreply@yourdomain.com>"

# ── LLM Providers (Optional fallbacks) ──
# Users provide their own keys via BYOK, but these are used as system fallbacks
OPENROUTER_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
TOGETHER_API_KEY=
