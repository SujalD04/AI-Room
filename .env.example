# ──────────────────────────────────────────
# AIRoom Environment Configuration
# Copy to .env and fill in values
# ──────────────────────────────────────────

# ── Server ──
NODE_ENV=development
PORT=3001
CLIENT_URL=http://localhost:3000

# ── Database ──
DATABASE_URL=postgresql://airoom:airoom_password@localhost:5432/airoom?schema=public

# ── Redis ──
REDIS_URL=redis://localhost:6379

# ── Auth ──
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_EXPIRES_IN=7d

# ── Encryption (BYOK) ──
ENCRYPTION_KEY=change-me-to-a-random-32-byte-hex-string

# ── mediasoup ──
MEDIASOUP_LISTEN_IP=0.0.0.0
MEDIASOUP_ANNOUNCED_IP=127.0.0.1
MEDIASOUP_MIN_PORT=40000
MEDIASOUP_MAX_PORT=49999

# ── LLM Providers (optional — users bring their own) ──
# These are fallback/system keys; users provide their own via BYOK
# OPENROUTER_API_KEY=
# GROQ_API_KEY=
# GEMINI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# DEEPSEEK_API_KEY=
# TOGETHER_API_KEY=
